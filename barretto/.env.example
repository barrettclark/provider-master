#!/bin/bash
# Environment Variables Template for Barretto Workspace
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual credentials in the .env file
# 3. Source the file before running terraform: source .env
# 4. NEVER commit the .env file to version control!

# Terraform Enterprise/Cloud API Token
# Get this from: https://app.staging.terraform.io/app/settings/tokens
export TF_VAR_tfe_token="your-tfe-token-here"

# GitHub OAuth Token for VCS integration
# Get this from: https://github.com/settings/tokens
export TF_VAR_github_oauth_token="your-github-token-here"

# AWS Credentials for variable sets
# Get these from AWS IAM console
export TF_VAR_aws_access_key_id="your-aws-access-key-here"
export TF_VAR_aws_secret_access_key="your-aws-secret-key-here"

# Non-sensitive values (these are also in main.auto.tfvars)
export TF_VAR_hostname="app.staging.terraform.io"
export TF_VAR_owner_email="your-email@hashicorp.com"

# USAGE:
# source .env && terraform plan
# source .env && terraform apply
